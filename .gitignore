# =========================================================
# Unreal Engine
# =========================================================

# Unreal generated folders
Binaries/
DerivedDataCache/
Intermediate/
Saved/

# Generated folders inside plugins
Plugins/**/Binaries/
Plugins/**/Intermediate/
Plugins/**/Saved/
Plugins/**/DerivedDataCache/

# =========================================================
# Visual Studio
# =========================================================

.vs/

# Unreal can regenerate these project files
*.sln
*.slnx
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# User-specific Visual Studio files
*.user
*.userosscache
*.sln.docstates

# Keep .vsconfig in Git so team members can install
# the required Visual Studio workloads.
# .vsconfig

# =========================================================
# C / C++ build outputs
# =========================================================

*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.ipch
*.iobj
*.ipdb
*.idb
*.ilk
*.exp
*.lib
*.dll
*.exe
*.pdb
*.tlog
*.lastbuildstate

# Dynamic/static libraries for other platforms
*.so
*.dylib
*.lai
*.la
*.a
*.out
*.app
*.ipa

# =========================================================
# Unreal Build folder
# =========================================================

# Ignore generated build content, but keep project resources
Build/*
!Build/**/*.ico
!Build/**/*.png
!Build/**/*.xml
!Build/**/*.plist
!Build/**/*.ini

# =========================================================
# IDEs and editors
# =========================================================

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains Rider / ReSharper
.idea/
_ReSharper*/
*.DotSettings.user

# =========================================================
# Python / AI server
# =========================================================

__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python build outputs
dist/
*.egg-info/

# API keys and local environment settings
.env
.env.*
!.env.example

